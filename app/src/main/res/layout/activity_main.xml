<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context="com.shijing.xomniclaw.ui.activity.MainActivity">

    <!-- 主内容区 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 标题栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="24dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="@string/app_name" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PhoneForClaw"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI 移动自动化平台"
                        android:textSize="14sp"
                        android:textColor="#666666" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v2.4.3"
                    android:textSize="12sp"
                    android:textColor="#999999" />
            </LinearLayout>

            <!-- Gateway 卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_gateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:contentDescription="Gateway" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gateway"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <TextView
                            android:id="@+id/tv_gateway_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="运行中"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:textColor="#4CAF50" />

                        <TextView
                            android:id="@+id/tv_gateway_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WebSocket: ws://0.0.0.0:8765"
                            android:textSize="12sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:contentDescription="查看详情" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 权限卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_permissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:contentDescription="权限" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="权限"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <TextView
                            android:id="@+id/tv_permissions_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已授权"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:textColor="#4CAF50" />

                        <TextView
                            android:id="@+id/tv_permissions_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="无障碍: ✓  悬浮窗: ✓  录屏: ✓"
                            android:textSize="12sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:contentDescription="查看详情" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Skills 卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_skills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:contentDescription="Skills" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Skills"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <TextView
                            android:id="@+id/tv_skills_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 个 Skills"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:textColor="#4CAF50" />

                        <TextView
                            android:id="@+id/tv_skills_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Always: 3  On-Demand: 5  Bundled: 8"
                            android:textSize="12sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:contentDescription="查看详情" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sessions 卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:contentDescription="Sessions" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sessions"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <TextView
                            android:id="@+id/tv_sessions_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="无活跃会话"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:textColor="#999999" />

                        <TextView
                            android:id="@+id/tv_sessions_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="暂无活跃的 Agent 会话"
                            android:textSize="12sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:contentDescription="查看详情" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 底部导航栏 -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottom_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:backgroundTint="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp">

            <Button
                android:id="@+id/btn_config"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="配置"
                android:textSize="14sp"
                android:drawableTop="@android:drawable/ic_menu_manage"
                android:drawablePadding="4dp" />

            <Button
                android:id="@+id/btn_test"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="检查更新"
                android:textSize="14sp"
                android:drawableTop="@android:drawable/ic_menu_compass"
                android:drawablePadding="4dp" />

            <Button
                android:id="@+id/btn_logs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="日志"
                android:textSize="14sp"
                android:drawableTop="@android:drawable/ic_menu_info_details"
                android:drawablePadding="4dp" />
        </LinearLayout>
    </com.google.android.material.bottomappbar.BottomAppBar>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
